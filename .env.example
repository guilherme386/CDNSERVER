# Proxy credentials
PROXY_HOST=proxy.example.com
PROXY_PORT=2101
PROXY_USER=seu_usuario_proxy
PROXY_PASS=sua_senha_proxy

# Xtream API
XTREAM_URL=https://seu-servidor-xtream.com
XTREAM_USERNAME=seu_usuario
XTREAM_PASSWORD=sua_senha

# Admin Panel credentials
Admin_login=seu_login_admin
Admin_pass=sua_senha_admin

# API Privada
API_KEY=sua_chave_api_aqui
TOKEN_SECRET=seu_segredo_hmac_minimo_32_chars

# Domains
CDN_DOMAIN=cdn.seudominio.com
PANEL_DOMAIN=painel.seudominio.com
ALLOWED_ORIGINS=https://painel.seudominio.com,http://localhost:3000

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Token expiration
EXTRA_EXPIRATION_MINUTES=60

# Logging
LOG_LEVEL=info
